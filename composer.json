{
  "name": "luxid/haven",
  "description": "Session-based authentication package for Luxid PHP Framework",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "luxid",
    "authentication",
    "auth",
    "session",
    "guard",
    "haven"
  ],
  "authors": [
    {
      "name": "Jhay",
      "email": "jhay@luxid.dev"
    }
  ],
  "require": {
    "php": "^8.0",
    "luxid/engine": "^0.7.1",
    "luxid/rocket": "^0.1.8"
  },
  "autoload": {
    "psr-4": {
      "Luxid\\Haven\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "@php bin/generate-bridge.php"
    ],
    "post-update-cmd": [
      "@php bin/generate-bridge.php"
    ]
  },
  "extra": {
    "luxid": {
      "providers": [
        "Luxid\\Haven\\Providers\\HavenServiceProvider"
      ],
      "commands": {
        "haven:install": "Luxid\\Haven\\Console\\InstallCommand"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
